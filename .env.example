APP_NAME=Parser KP
APP_ENV=dev
# Local dev: change-me is fine. Production: use a long random value.
SECRET_KEY=change-me
# Comma-separated emails for admin API + admin UI tab (case-insensitive).
ADMIN_EMAILS=admin@local
# Local dev: true seeds demo users + sample catalog. Production on a public IP: set false.
SEED_DEMO_USERS=true
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/parser_kp
REDIS_URL=redis://redis:6379/0
RQ_QUEUE=default
STORAGE_ROOT=/app/storage
HYBRID_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=catalog_products
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
